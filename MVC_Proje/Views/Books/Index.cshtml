@model IEnumerable<MVC_Proje.Models.Book>

<h2>Kitap Listesi</h2>

<p>
    <a asp-action="Add" class="btn btn-primary">Yeni Kitap Ekle</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Author</th>
            <th>Price</th>
            <th>Stock</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Author</td>
                <td>@item.Price</td>
                <td>@item.Stock</td>
                <td>
                    <a asp-action="Update" asp-route-id="@item.Id" class="btn btn-warning">Güncelle</a>
                    <a asp-action="Remove" asp-route-id="@item.Id" class="btn btn-danger" onclick="return confirm('Silmek istediğinize emin misiniz?')">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>