@model IEnumerable<MVC_Proje.Models.Book>

<div class="container mt-4">
    <h2>Kitap Listesi</h2>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success">
            @TempData["Message"]
        </div>
    }

    <p>
        <a asp-action="Add" class="btn btn-primary">Yeni Kitap Ekle</a>
    </p>

    <form asp-action="Index" method="get" class="mb-4">
        <div class="row g-3">
            <div class="col-md-4">
                <input type="text" name="searchString" value="@ViewBag.CurrentSearch" class="form-control" placeholder="Kitap adı ara..." />
            </div>

            <div class="col-md-3">
                <select name="categoryId" class="form-select">
                    <option value="">Tüm Kategoriler</option>
                    @foreach (var cat in ViewBag.Categories)
                    {
                        <option value="@cat.Id" selected="@(ViewBag.CurrentCategory == cat.Id ? "selected" : null)">@cat.Name</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <select name="sortOrder" class="form-select">
                    <option value="name_asc" selected="@(ViewBag.CurrentSort == "name_asc" ? "selected" : null)">Ad (A-Z)</option>
                    <option value="name_desc" selected="@(ViewBag.CurrentSort == "name_desc" ? "selected" : null)">Ad (Z-A)</option>
                    <option value="price_asc" selected="@(ViewBag.CurrentSort == "price_asc" ? "selected" : null)">Fiyat (Artan)</option>
                    <option value="price_desc" selected="@(ViewBag.CurrentSort == "price_desc" ? "selected" : null)">Fiyat (Azalan)</option>
                </select>
            </div>

            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Filtrele</button>
            </div>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Aradığınız kriterlere uygun kitap bulunamadı.</div>
    }

    <table class="table table-striped table-hover mt-3">
        <thead class="table-dark">
            <tr>
                <th>Kitap Adı</th>
                <th>Yazar</th>
                <th>Kategori</th>
                <th>Fiyat</th>
                <th>Stok Miktarı</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Author</td>
                    <th>@item.Category.Name</th>
                    <td>@item.Price.ToString("C2")</td>
                    <td>@item.Stock</td>
                    <td>
                        <a asp-action="Update" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Güncelle</a>
                        <a asp-action="Remove" asp-route-id="@item.Id" class="btn btn-danger btn-sm" onclick="return confirm('Silmek istediğinize emin misiniz?')">Sil</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>